{
	  "manifest_version" : 3,
	  "name" : "Sort tabs advanced",
	  "version" : "0.3",
	  "author" : "Mois Moshev <mois@monomon.me>",
	  "icons" : {
		    "48" : "icons/sortabs-48.png"
	  },
	  "description" : "Sort tabs by various criteria",
	  "action" : {
		    "default_icon" : {
			      "16" : "icons/sortabs-16.png",
			      "24" : "icons/sortabs-24.png",
			      "48" : "icons/sortabs-48.png"
		    },
		    "default_title" : "Sort tabs advanced",
		    "default_popup" : "popup/picker.html"
	  },
	  "permissions" : [
		    "tabs",
        "tabGroups",
        "storage"
	  ],
    "browser_specific_settings": {
        "gecko": {
            "id": "{d6f02b92-88b3-4aa5-ba7c-14519042171d}"
        }
    },
    "background": {
        "scripts": ["background.js"]
    }
}
